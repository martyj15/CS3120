    "    grad_b = (dloss_dypred * dypred_dlinpred * dlinpred_db).sum()\n",
    "    w -= learning_rate * grad_w # calculate w^(k+1) from w^(k)\n",
    "    b -= learning_rate * grad_b # calculate b^(k+1) from b^(k)\n",
